---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  locale?: string
}

const {
  title = 'Humberto Lopez — Fullstack Developer',
  description = 'Software Development Engineer specialized in Java/Spring, TypeScript, Angular, React and Python.',
  locale = 'es',
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site)
const esUrl = new URL(Astro.url.pathname.replace(/^\/en\//, '/'), Astro.site)
const enUrl = new URL(
  Astro.url.pathname.startsWith('/en/') ? Astro.url.pathname : `/en${Astro.url.pathname}`,
  Astro.site
)
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#0a1620" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="canonical" href={canonical.href} />
    <link rel="alternate" hreflang="es" href={esUrl.href} />
    <link rel="alternate" hreflang="en" href={enUrl.href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:locale" content={locale === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:site_name" content="Humberto Lopez — Portfolio" />

    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-100 focus:bg-cyan focus:text-paper focus:px-4 focus:py-2 focus:font-pixel focus:text-[12px]"
      >Skip to content</a
    >
    <slot />
    <script>
      document.querySelectorAll('.scroll-reveal').forEach(el => {
        const observer = new IntersectionObserver(
          entries => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible')
                observer.unobserve(entry.target)
              }
            })
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        )
        observer.observe(el)
      })
    </script>
  </body>
</html>
