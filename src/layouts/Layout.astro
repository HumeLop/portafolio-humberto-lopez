---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Humberto Lopez — Fullstack Developer',
  description = 'Ingeniero en Desarrollo y Gestión de Software especializado en Java/Spring, TypeScript, Angular, React y Python.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
