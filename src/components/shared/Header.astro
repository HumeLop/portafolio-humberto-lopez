---
import { getDict } from '../../i18n'

const locale = (Astro.currentLocale ?? 'es') as 'es' | 'en'
const t = getDict(locale)
const switchHref = locale === 'es' ? '/en/' : '/'
const switchLabel = locale === 'es' ? 'EN' : 'ES'

const links = [
  { href: '#about', label: t.header.about },
  { href: '#skills', label: t.header.stats },
  { href: '#experience', label: t.header.quests },
  { href: '#education', label: t.header.academy },
  { href: '#projects', label: t.header.inventory },
  { href: '#certs', label: t.header.trophies },
  { href: '#contact', label: t.header.message },
]
---

<header class="fixed top-0 inset-x-0 z-50 bg-paper/92 border-b-2 border-line">
  <div class="container h-16 flex items-center justify-between gap-6">
    <a href="#top" class="font-pixel text-[11px] text-ink tracking-wider shrink-0 no-underline">
      <span class="text-cyan">▶</span> HL<span
        class="text-cyan animate-[blink_1.1s_step-end_infinite]">_</span
      >
    </a>

    <nav class="hidden md:flex items-center gap-5 flex-1 justify-center">
      {
        links.map(l => (
          <a
            href={l.href}
            class="font-pixel text-[9px] text-ink-dim tracking-wider no-underline px-2 py-1 border border-transparent transition-all duration-150 hover:text-cyan hover:border-cyan hover:animate-pulsing"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a
        href={switchHref}
        class="font-pixel text-[9px] text-gold tracking-wider no-underline px-2 py-1 border border-gold/30 hover:border-gold hover:animate-pulsing transition-all duration-150"
      >
        {switchLabel}
      </a>
      <div class="flex items-center gap-2 font-pixel text-[9px] tracking-wider text-green shrink-0">
        <span class="dot"></span>{t.header.online}
      </div>
    </div>

    <div class="flex md:hidden items-center gap-2">
      <a
        href={switchHref}
        class="font-pixel text-[8px] text-gold tracking-wider no-underline px-1.5 py-0.5 border border-gold/30"
      >
        {switchLabel}
      </a>
      <button
        type="button"
        class="flex flex-col gap-1.5 bg-transparent border-3 border-ink-dim p-2 cursor-pointer"
        aria-label={t.header.menu}
        id="navToggle"
      >
        <span class="w-5 h-0.75 bg-cyan"></span>
        <span class="w-5 h-0.75 bg-cyan"></span>
        <span class="w-5 h-0.75 bg-cyan"></span>
      </button>
    </div>
  </div>

  <nav class="hidden flex-col bg-panel border-t-3 border-line px-5 pb-5 pt-2" id="navMobile">
    {
      links.map(l => (
        <a
          href={l.href}
          class="menu-cursor py-3.5 border-b-2 border-line font-pixel text-[9px] text-ink-dim no-underline"
        >
          {l.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle')
  const mobile = document.getElementById('navMobile')
  toggle?.addEventListener('click', () => {
    mobile?.classList.toggle('hidden')
    mobile?.classList.toggle('flex')
  })
  mobile?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobile.classList.add('hidden')
      mobile.classList.remove('flex')
    })
  })
</script>
