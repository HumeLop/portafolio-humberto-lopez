---
import { getDict } from '../../i18n'

const t = getDict((Astro.currentLocale ?? 'es') as 'es' | 'en')
---

<section id="about" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t.about.eyebrow}</p>
        <h2 class="text-[22px] md:text-[28px] font-normal">{t.about.title}</h2>
      </div>
      <span class="section-index">{t.about.sectionIndex}</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[1.6fr_1fr] gap-10 items-start">
      <p class="text-[16px] text-ink-dim leading-[1.85]">
        {t.about.bio1}
        <br /><br />
        {t.about.bio2}
      </p>

      <div class="panel">
        <p class="font-pixel text-[9px] tracking-wider text-magenta uppercase mb-4">
          {t.about.playStyle}
        </p>
        <ul class="flex flex-col gap-3.5 list-none m-0 p-0">
          <li
            class="text-[13px] text-ink pl-5 relative before:content-['▹'] before:absolute before:left-0 before:text-cyan"
          >
            {t.about.p1}
          </li>
          <li
            class="text-[13px] text-ink pl-5 relative before:content-['▹'] before:absolute before:left-0 before:text-cyan"
          >
            {t.about.p2}
          </li>
          <li
            class="text-[13px] text-ink pl-5 relative before:content-['▹'] before:absolute before:left-0 before:text-cyan"
          >
            {t.about.p3}
          </li>
          <li
            class="text-[13px] text-ink pl-5 relative before:content-['▹'] before:absolute before:left-0 before:text-cyan"
          >
            {t.about.p4}
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
