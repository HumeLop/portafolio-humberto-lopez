---
import { getDict } from '../../i18n'

const t = getDict((Astro.currentLocale ?? 'es') as 'es' | 'en')
---

<section id="education" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t.education.eyebrow}</p>
        <h2 class="text-[22px] md:text-[28px] font-normal">{t.education.title}</h2>
      </div>
      <span class="section-index">{t.education.sectionIndex}</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5.5">
      {
        t.education.entries.map((edu, i) => (
          <div class="panel scroll-reveal" style={`transition-delay:${i * 100}ms`}>
            <div class="flex flex-col gap-1.5 mb-3">
              <h3 class="text-[16px] font-normal">{edu.degree}</h3>
              <p class="font-mono text-[12px] text-cyan">{edu.school}</p>
            </div>
            <p class="font-mono text-[10px] text-ink-low tracking-wider">{edu.period}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
