---
const education = [
	{
		school: 'Universidad Tecnológica de Tehuacán',
		degree: 'Ingeniería en Desarrollo y Gestión de Software',
		period: '2020 — 2022',
	},
	{
		school: 'Universidad Tecnológica de Tehuacán',
		degree: 'TSU en Desarrollo de Software Multiplataforma',
		period: '2018 — 2020',
	},
]
---

<section id="education" class="py-16">
	<div class="container">
		<div class="section-head">
			<div>
				<p class="eyebrow">04 — Formacion</p>
				<h2 class="text-[28px] md:text-[40px] font-semibold">Educacion</h2>
			</div>
			<span class="section-index">EDUCATION.md</span>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 gap-5.5">
			{education.map((edu) => (
				<div class="panel">
					<div class="flex flex-col gap-1.5 mb-3">
						<h3 class="text-xl font-semibold">{edu.degree}</h3>
						<p class="font-mono text-violet text-[13.5px]">{edu.school}</p>
					</div>
					<p class="font-mono text-[11.5px] text-low tracking-wide">{edu.period}</p>
				</div>
			))}
		</div>
	</div>
</section>
