---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import { getDict } from '../../i18n'

const projects = (await getCollection('projects')).filter(p => p.data.featured)
const t = getDict((Astro.currentLocale ?? 'es') as 'es' | 'en')
---

<section id="projects" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t.projects.eyebrow}</p>
        <h2 class="text-[22px] md:text-[28px] font-normal">{t.projects.title}</h2>
      </div>
      <span class="section-index">{t.projects.sectionIndex}</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((entry, i) => (
          <article class="panel scroll-reveal group" style={`transition-delay:${i * 10}ms`}>
            <div class="aspect-16/10 -mx-5 sm:-mx-7 -mt-5 sm:-mt-7 mb-5 border-b-2 border-line flex items-center justify-center overflow-hidden bg-[linear-gradient(135deg,#0a1620,#0e1e2e)] hover:animate-float">
              {entry.data.image ? (
                <Image
                  src={entry.data.image}
                  alt={entry.data.title}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span class="font-pixel text-[8px] tracking-wider text-ink-low">
                  {t.projects.noImage}
                </span>
              )}
            </div>
            <p class="font-mono text-[10px] text-cyan tracking-wider mb-2">{entry.id}</p>
            <h3 class="text-[15px] font-normal mb-2.5">{entry.data.title}</h3>
            <p class="text-[13px] text-ink-dim mb-4.5 min-h-14.5">{entry.data.description}</p>
            <div class="flex flex-wrap gap-1.5 mb-5">
              {entry.data.stack.map(s => (
                <span class="tag hover:animate-pulsing">{s}</span>
              ))}
            </div>
            <a
              target="_blank"
              rel="noopener noreferrer"
              class="font-pixel text-[8px] text-cyan tracking-wider no-underline hover:animate-pulsing"
              href={entry.data.url ?? '/'}
            >
              {t.projects.view}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
