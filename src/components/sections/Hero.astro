---
import { getDict } from '../../i18n'

const locale = (Astro.currentLocale ?? 'es') as 'es' | 'en'
const t = getDict(locale)
---

<section
  class="pt-32 sm:pt-44 pb-16 sm:pb-24 min-h-[92vh] flex flex-col justify-center relative"
  id="top"
>
  <div class="container grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-14 items-center">
    <div class="max-w-155">
      <p
        class="font-pixel text-[9px] tracking-wider text-cyan uppercase mb-5 flex items-center gap-2 animate-fade-in"
      >
        <span class="animate-[blink_1s_step-end_infinite]">■</span>
        {t.hero.tagline}
      </p>

      <h1
        class="text-[28px] sm:text-[42px] md:text-[64px] leading-[1.1] font-normal mb-3 text-ink animate-fade-in animate-delay-100"
      >
        HUMBERTO<br />LOPEZ
      </h1>

      <p class="font-mono text-base text-cyan mb-8 animate-fade-in animate-delay-200">
        &gt; {t.hero.role}
      </p>

      <p
        class="text-[15px] text-ink-dim max-w-130 mb-9 leading-relaxed animate-fade-in animate-delay-300"
        set:html={t.hero.bio}
      />

      <div class="flex gap-2 sm:gap-3 flex-wrap animate-fade-in animate-delay-500">
        <a class="btn primary" href="#contact">{t.hero.btnContact}</a>
        <a class="btn" href="https://github.com/HumeLop" target="_blank" rel="noopener noreferrer"
          >{t.hero.btnGH}</a
        >
        <a
          class="btn"
          href="https://www.linkedin.com/in/humberto-lopez24/"
          target="_blank"
          rel="noopener noreferrer">{t.hero.btnLI}</a
        >
      </div>
    </div>

    <aside class="panel animate-fade-in-right animate-delay-400">
      <p
        class="font-pixel text-[9px] tracking-wider text-gold uppercase mb-5 pb-3 border-b-2 border-dashed border-line-bright"
      >
        {t.hero.statusTitle}
      </p>
      <ul class="flex flex-col gap-4">
        <li class="flex justify-between gap-3 text-[13px]">
          <span class="font-mono text-[10px] tracking-wider text-cyan shrink-0">{t.hero.class}</span
          >
          <span class="text-ink text-right">{t.hero.classVal}</span>
        </li>
        <li class="flex justify-between gap-3 text-[13px]">
          <span class="font-mono text-[10px] tracking-wider text-cyan shrink-0">{t.hero.level}</span
          >
          <span class="text-ink text-right">{t.hero.levelVal}</span>
        </li>
        <li class="flex justify-between gap-3 text-[13px]">
          <span class="font-mono text-[10px] tracking-wider text-cyan shrink-0">{t.hero.guild}</span
          >
          <span class="text-ink text-right">{t.hero.guildVal}</span>
        </li>
        <li class="flex justify-between gap-3 text-[13px]">
          <span class="font-mono text-[10px] tracking-wider text-cyan shrink-0">{t.hero.spec}</span>
          <span class="text-ink text-right">{t.hero.specVal}</span>
        </li>
        <li class="flex justify-between gap-3 text-[13px]">
          <span class="font-mono text-[10px] tracking-wider text-cyan shrink-0">{t.hero.align}</span
          >
          <span class="text-ink text-right">{t.hero.alignVal}</span>
        </li>
      </ul>
      <div
        class="mt-5 pt-4 border-t-2 border-dashed border-line-bright font-pixel text-[7px] tracking-wider text-green flex items-center gap-2"
      >
        <span class="dot"></span>{t.hero.lfg}
      </div>
    </aside>
  </div>

  <div
    class="hidden md:flex absolute bottom-6 left-8 items-center gap-2.5 font-pixel text-[8px] tracking-wider text-ink-low"
  >
    <span>{t.hero.scroll}</span>
    <span class="w-10 h-0.75 bg-cyan"></span>
  </div>
</section>
