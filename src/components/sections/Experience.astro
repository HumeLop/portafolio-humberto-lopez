---
import { getDict } from '../../i18n'

const t = getDict((Astro.currentLocale ?? 'es') as 'es' | 'en')
---

<section id="experience" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t.experience.eyebrow}</p>
        <h2 class="text-[22px] md:text-[28px] font-normal">{t.experience.title}</h2>
      </div>
      <span class="section-index">{t.experience.sectionIndex}</span>
    </div>

    <div class="relative flex flex-col gap-10">
      {
        t.experience.jobs.map((q, i) => (
          <div
            class="grid grid-cols-[20px_1fr] gap-5 scroll-reveal"
            style={`transition-delay:${i * 50}ms`}
          >
            <div class="flex justify-center pt-6 hover:animate-pulsing">
              <div class={`quest-marker ${!q.active ? 'complete' : ''}`} />
            </div>

            <div class="panel">
              <div class="flex items-center justify-between gap-3 mb-1.5">
                <h3 class="text-[15px] font-normal">{q.company}</h3>
                {q.active ? (
                  <span class="font-pixel text-[7px] text-green tracking-wider border-2 border-green px-2 py-0.5">
                    {t.experience.inProgress}
                  </span>
                ) : (
                  <span class="font-pixel text-[7px] text-ink-low tracking-wider border-2 border-line-bright px-2 py-0.5">
                    {t.experience.completed}
                  </span>
                )}
              </div>
              <p class="font-mono text-[12px] text-cyan mb-1">{q.role}</p>
              <p class="font-mono text-[10px] text-ink-low tracking-wider mb-4">{q.period}</p>
              <div class="border-t-2 border-line pt-3.5">
                <p class="font-pixel text-[8px] text-gold tracking-wider mb-3">
                  {t.experience.objectivesTitle}
                </p>
                <ul class="flex flex-col gap-2 list-none m-0 p-0">
                  {q.objectives.map(o => (
                    <li class="text-[13px] text-ink-dim pl-5 relative before:content-['☐'] before:absolute before:left-0 before:text-cyan before:text-[11px]">
                      {o}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
