---
import { getDict } from '../../i18n'
import { SOCIAL_LINKS } from '../../lib/constants'
import Button from '../ui/Button.astro'

const t = getDict((Astro.currentLocale ?? 'es') as 'es' | 'en')
---

<section id="contact" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t.contact.eyebrow}</p>
        <h2 class="text-[22px] md:text-[28px] font-normal">{t.contact.title}</h2>
      </div>
      <span class="section-index">{t.contact.sectionIndex}</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.1fr] gap-12">
      <div>
        <p class="text-[16px] text-ink leading-relaxed mb-8 max-w-105">
          {t.contact.intro}
        </p>

        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            SOCIAL_LINKS.map(link => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener"
                  class="panel flex items-center gap-4 py-4.5 px-5 text-sm text-ink-dim no-underline hover:animate-pulsing"
                >
                  <span class="font-pixel text-[8px] text-cyan tracking-wider shrink-0 w-22">
                    {link.platform.toUpperCase()}
                  </span>
                  <span>{new URL(link.href).pathname}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <form
        class="panel flex flex-col gap-4.5"
        id="contact-form"
        data-btn-send={t.contact.btnSend}
        data-btn-sending={t.contact.btnSending}
        data-btn-sent={t.contact.btnSent}
        data-btn-error={t.contact.btnError}
        data-btn-noconn={t.contact.btnNoConn}
      >
        <label class="flex flex-col gap-2 font-pixel text-[9px] tracking-wider text-ink-low">
          {t.contact.labelName}
          <input
            type="text"
            name="name"
            placeholder={t.contact.phName}
            required
            class="pixel-input"
          />
        </label>
        <label class="flex flex-col gap-2 font-pixel text-[9px] tracking-wider text-ink-low">
          {t.contact.labelEmail}
          <input
            type="email"
            name="email"
            placeholder={t.contact.phEmail}
            required
            class="pixel-input"
          />
        </label>
        <label class="flex flex-col gap-2 font-pixel text-[9px] tracking-wider text-ink-low">
          {t.contact.labelMessage}
          <textarea
            name="message"
            rows="5"
            placeholder={t.contact.phMessage}
            required
            class="pixel-input resize-y"></textarea>
        </label>
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          aria-hidden="true"
          tabindex="-1"
          autocomplete="off"
        />
        <Button type="submit" variant="primary">{t.contact.btnSend}</Button>
      </form>
    </div>
  </div>
</section>

<script>
  ;(() => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null
    if (!form) return

    const t = {
      send: form.dataset.btnSend || '▶ SEND',
      sending: form.dataset.btnSending || 'SENDING...',
      sent: form.dataset.btnSent || 'SENT!',
      error: form.dataset.btnError || 'ERROR',
      noconn: form.dataset.btnNoconn || 'NO CONNECTION',
    }

    form.addEventListener('submit', async e => {
      e.preventDefault()

      const button = form.querySelector('button') as HTMLButtonElement
      button.disabled = true
      button.textContent = t.sending

      try {
        const formData = new FormData(form)
        formData.append('access_key', 'YOUR_WEB3FORMS_ACCESS_KEY')

        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        })

        const result = await response.json()

        if (result.success) {
          button.textContent = t.sent
          button.classList.add('btn', 'primary')
          form.reset()
          setTimeout(() => {
            button.textContent = t.send
            button.disabled = false
          }, 3000)
        } else {
          button.textContent = t.error
          button.disabled = false
        }
      } catch {
        button.textContent = t.noconn
        button.disabled = false
      }
    })
  })()
</script>
