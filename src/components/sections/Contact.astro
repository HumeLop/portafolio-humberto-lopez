---
import { SOCIAL_LINKS } from '../../lib/constants'
import Button from '../ui/Button.astro'
---

<section id="contact" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">07 — Enlace</p>
        <h2 class="text-[28px] md:text-[40px] font-semibold">Contacto</h2>
      </div>
      <span class="section-index">CONTACT.init</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.1fr] gap-12">
      <div>
        <p class="text-[17px] text-hi leading-relaxed mb-8.5 max-w-105">
          ¿Tienes un proyecto en mente o buscas sumar a alguien al equipo? Escríbeme, respondo
          rápido.
        </p>

        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            SOCIAL_LINKS.map(link => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener"
                  class="panel flex items-center gap-4 py-4 px-5 text-sm text-hi"
                >
                  <span class="font-mono text-[11px] text-cyan tracking-wide shrink-0 w-19.5">
                    {link.platform.toUpperCase()}
                  </span>
                  <span>{new URL(link.href).pathname}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <form class="panel flex flex-col gap-4.5" id="contact-form">
        <label class="flex flex-col gap-2 font-mono text-[11px] tracking-wide text-low">
          NOMBRE
          <input
            type="text"
            name="name"
            placeholder="Tu nombre"
            required
            class="font-body text-[14.5px] text-hi bg-panel-raised border border-line-bright rounded-sm py-3 px-3.5
						focus:outline-none focus:border-cyan focus:shadow-[0_0_0_3px_rgba(77,250,255,0.12)]"
          />
        </label>
        <label class="flex flex-col gap-2 font-mono text-[11px] tracking-wide text-low">
          EMAIL
          <input
            type="email"
            name="email"
            placeholder="tu@email.com"
            required
            class="font-body text-[14.5px] text-hi bg-panel-raised border border-line-bright rounded-sm py-3 px-3.5
						focus:outline-none focus:border-cyan focus:shadow-[0_0_0_3px_rgba(77,250,255,0.12)]"
          />
        </label>
        <label class="flex flex-col gap-2 font-mono text-[11px] tracking-wide text-low">
          MENSAJE
          <textarea
            name="message"
            rows="5"
            placeholder="Cuéntame sobre tu proyecto..."
            required
            class="font-body text-[14.5px] text-hi bg-panel-raised border border-line-bright rounded-sm py-3 px-3.5 resize-y
						focus:outline-none focus:border-cyan focus:shadow-[0_0_0_3px_rgba(77,250,255,0.12)]"
          ></textarea>
        </label>
        <input type="checkbox" name="botcheck" class="hidden" />
        <Button type="submit" variant="primary">Enviar mensaje</Button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null
  if (!form) throw new Error('Contact form not found')

  const ACCESS_KEY = 'YOUR_WEB3FORMS_ACCESS_KEY'

  form.addEventListener('submit', async e => {
    e.preventDefault()

    const button = form.querySelector('button') as HTMLButtonElement
    button.disabled = true
    button.textContent = 'Enviando...'

    try {
      const formData = new FormData(form)
      formData.append('access_key', ACCESS_KEY)

      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      })

      const result = await response.json()

      if (result.success) {
        button.textContent = 'Mensaje enviado'
        button.classList.add('btn', 'primary')
        form.reset()
        setTimeout(() => {
          button.textContent = 'Enviar mensaje'
          button.disabled = false
        }, 3000)
      } else {
        button.textContent = 'Error al enviar'
        button.disabled = false
      }
    } catch {
      button.textContent = 'Error de conexión'
      button.disabled = false
    }
  })
</script>
