---
import { getDict } from '../../i18n'

const t = getDict((Astro.currentLocale ?? 'es') as 'es' | 'en')

const rarityColors: Record<string, string> = {
  gold: 'text-gold',
  silver: 'text-ink-dim',
}
---

<section id="certs" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">{t.certifications.eyebrow}</p>
        <h2 class="text-[22px] md:text-[28px] font-normal">{t.certifications.title}</h2>
      </div>
      <span class="section-index">{t.certifications.sectionIndex}</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        t.certifications.entries.map((c, i) => (
          <div
            class={`panel flex items-center gap-4 ${rarityColors[c.rarity]} scroll-reveal`}
            style={`transition-delay:${i * 10}ms`}
          >
            <span class="font-pixel text-[18px] shrink-0 hover:animate-pulsing" aria-hidden="true">
              {c.rarity === 'gold' ? '★' : '☆'}
            </span>
            <div>
              <p class="font-pixel text-[7px] tracking-wider text-ink-low mb-1.5">
                {t.certifications.achievement} {String(i + 1).padStart(2, '0')}
              </p>
              <p class="text-[14px] text-ink font-medium">{c.title}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
