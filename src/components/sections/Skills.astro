---
const categories = [
  {
    id: 'BACKEND',
    title: 'Backend',
    items: ['Java', 'Spring Boot', 'Python', 'PHP', 'Laravel'],
  },
  {
    id: 'FRONTEND',
    title: 'Frontend',
    items: ['Angular', 'React', 'Vue', 'Ionic', 'TypeScript', 'JavaScript', 'HTML', 'CSS'],
  },
  {
    id: 'DATA',
    title: 'Bases de datos',
    items: ['Oracle · Apex', 'MariaDB', 'MongoDB', 'SQL Server', 'Firebase'],
  },
  {
    id: 'VCS',
    title: 'Control de versiones',
    items: ['Git', 'GitLab', 'GitHub'],
  },
  {
    id: 'AGILE',
    title: 'Metodologías',
      items: ['Scrum'],
  },
]
---

<section id="skills" class="py-16">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">02 — Inventario</p>
        <h2 class="text-[28px] md:text-[40px] font-semibold">Stack técnico</h2>
      </div>
      <span class="section-index">SKILLS.tree</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5.5">
      {
        categories.map(cat => (
          <div class="panel">
            <div class="flex flex-col gap-1.5 mb-5">
              <span class="font-mono text-[11px] text-cyan-dim tracking-wide">[{cat.id}]</span>
              <h3 class="text-[19px] font-semibold">{cat.title}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {cat.items.map(item => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
